<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    :root {
      --base-font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      --heading-font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      --base-font-size: 16px;
      --base-font-style: normal;
      --base-font-weight: 400;
      --base-line-height: 1.6;
    }
    .mode-light:root, :root {
      --color-accent: #000000;
      --background-color: #ffffff;
      --background-alt-color: #f9f9f9;
      --background-gradient-start: #ffffff;
      --background-gradient-end: #ffffff;
      --text-color: #333333;
      --text-alt-color: #666666;
      --heading-font-color: #111111;
      --link-color: #0044cc;
      --link-color-hover: #002288;
      --border-color: #eeeeee;
      --code-color: #cc0000;
      --code-background-color: #f4f4f4;
    }
  </style>

  {% block head %}
    {# Check if _tag is defined for tag pages #}
    {% if _tag is defined %}
      <title>
        {% if _tag.name == "Politics" %}
          Politics in Madeira | Government News & Legislative Updates
        {% elseif _tag.name == "Funchal" %}
          Funchal News | Latest Updates from Madeira's Capital
        {% elseif _tag.name == "traffic" %}
          Madeira Traffic | Roads, Cars & Transport in Madeira
        {% elseif _tag.name == "Airport" %}
          Madeira Airport News | Flight Status, Delays & Updates
        {% elseif _tag.name == "Rescue" %}
          Rescue Operations Madeira | Emergency Services & Safety News
        {% elseif _tag.name == "Nature" %}
          Madeira Nature & Environment | Laurissilva Forest & Wildlife
        {% elseif _tag.name == "Tourism" %}
          Madeira Tourism News | Travel Trends & Visitor Information
        {% elseif _tag.name == "Record" %}
          Madeira Records | Achievements & Historic Milestones
        {% elseif _tag.name == "Real-estate" %}
          Madeira Real Estate Market | Property News & Investments
        {% elseif _tag.name == "Society" %}
          Madeira Society | Community News, People & Lifestyle
        {% elseif _tag.name == "Weather forecast" %}
          Madeira Weather Forecast | Local Climate & Daily Outlook
        {% elseif _tag.name == "Economy" %}
          Madeira Economy | Business, Finance & Trade News
        {% elseif _tag.name == "Natural disaster" %}
          Madeira Natural Disasters | Alerts, Recovery & Safety
        {% elseif _tag.name == "Crime" %}
          Crime News Madeira | Public Safety & Local Incident Reports
        {% elseif _tag.name == "Police-investigation" %}
          Police Investigations Madeira | Judiciary & Legal Updates
        {% elseif _tag.name == "History" %}
          Madeira History | Exploring the Archipelago's Rich Past
        {% elseif _tag.name == "Climate transition" %}
          Climate Transition Madeira | Sustainability & Green Energy
        {% elseif _tag.name == "Culture" %}
          Culture in Madeira | Traditions, Arts & Local Heritage
        {% else %}
          Times of Madeira | Breaking Madeira Island News
        {% endif %}
      </title>

      <meta name="description" content="
        {% if _tag.name == "Politics" %}
